@page
@model PulseHub.Pages.ReportsModel
@{
    ViewData["Title"] = "Reports";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold">Reports</h2>
        <p class="text-muted">Select a report to view</p>
    </div>

    <div class="row row-cols-1 row-cols-md-2 g-4 justify-content-center">

        <div class="col">
            <a href="/Reports/Recognition" class="text-decoration-none">
                <div class="card shadow-sm h-100 border-success report-card">
                    <div class="card-body text-center py-5">
                        <i class="bi bi-star-fill text-success mb-3" style="font-size: 3rem;"></i>
                        <h4 class="fw-bold text-success">Recognition</h4>
                        <p class="text-muted mb-0">Employees recognized by customers in survey responses (green flagged). Filter by date range.</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col">
            <a href="/Reports/Followup" class="text-decoration-none">
                <div class="card shadow-sm h-100 border-danger report-card">
                    <div class="card-body text-center py-5">
                        <i class="bi bi-flag-fill text-danger mb-3" style="font-size: 3rem;"></i>
                        <h4 class="fw-bold text-danger">Follow-up Status</h4>
                        <p class="text-muted mb-0">Curated items flagged for manager follow-up. Color coded by action status.</p>
                    </div>
                </div>
            </a>
        </div>

    </div>
</div>

<style>
    .report-card {
        transition: transform 0.15s, box-shadow 0.15s;
        cursor: pointer;
    }
    .report-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.12) !important;
    }
</style>
