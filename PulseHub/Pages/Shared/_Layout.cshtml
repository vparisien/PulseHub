@{
    var version = "v1.0.0";
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — PulseHub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .ph-navbar {
            background-color: #1a1a2e;
        }
        .ph-navbar .nav-link {
            color: rgba(255,255,255,0.75);
            font-size: 0.9rem;
            padding: 0.5rem 1rem;
            border-radius: 6px;
            transition: background 0.15s, color 0.15s;
        }
        .ph-navbar .nav-link:hover {
            background: rgba(255,255,255,0.1);
            color: #fff;
        }
        .ph-navbar .nav-link.active {
            background: rgba(255,255,255,0.18);
            color: #fff;
            font-weight: 600;
        }
        .ph-navbar .nav-link i {
            margin-right: 5px;
        }
        .ph-brand {
            color: #fff;
            font-weight: 700;
            font-size: 1.1rem;
            text-decoration: none;
            letter-spacing: 0.5px;
        }
        .ph-brand:hover { color: #fff; }
    </style>
</head>
<body>

    <!-- Top Navigation -->
    <nav class="navbar ph-navbar px-3 py-2 mb-0">
        <a href="/" class="ph-brand me-4">
            <img src="~/images/logo.png" alt="PulseHub" height="30" class="me-2" style="vertical-align:middle;" />
            PulseHub
        </a>
        <div class="d-flex flex-wrap gap-1 align-items-center">
            <a href="/" class="nav-link @(currentPage == "/" || currentPage == "/Index" ? "active" : "")">
                <i class="bi bi-house"></i> Home
            </a>
            <a href="/ImportSurveys" class="nav-link @(currentPage == "/ImportSurveys" ? "active" : "")">
                <i class="bi bi-file-earmark-arrow-up"></i> Import
            </a>
            <a href="/CurateResponses" class="nav-link @(currentPage == "/CurateResponses" ? "active" : "")">
                <i class="bi bi-pencil-square"></i> Curate
            </a>
            <a href="/Reports" class="nav-link @(currentPage == "/Reports" ? "active" : "")">
                <i class="bi bi-bar-chart-line"></i> Reports
            </a>
        </div>
        <div class="ms-auto d-flex align-items-center gap-3">
            <span class="text-white-50 small">@version</span>
            @{
                var sessionUser = Context.Session.GetString("DisplayName") ?? Context.Session.GetString("Username");
            }
            @if (!string.IsNullOrEmpty(sessionUser))
            {
                <span class="text-white-50 small"><i class="bi bi-person-circle me-1"></i>@sessionUser</span>
                <a href="/Logout" class="nav-link py-1 px-2" title="Sign out"><i class="bi bi-box-arrow-right"></i></a>
            }
        </div>
    </nav>
    <hr class="m-0" style="border-color: rgba(255,255,255,0.1);" />

    <!-- Main content -->
    <div class="content">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)

</body>
</html>
