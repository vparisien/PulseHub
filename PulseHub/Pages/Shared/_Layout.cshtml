@{
    var version = "v1.0.0"; // You can later bind this dynamically from config
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />


</head>
<body>

    <!-- Header -->
    <header class="header">
        <div class="header-left">
            <img src="~/images/logo.png" alt="Logo" class="logo" width="150px" />
        </div><br />
        <div class="text-end">
            <span class="text-muted small">@version</span><br />
            <span class="text-muted smaller">

            </span>
        </div>
    </header>

    <!-- Separator line -->
    <hr class="divider" />

    <!-- Navigation bar -->
    <nav class="navbar custom-navbar">
@*         <a href="@Url.Content("~/")">Home</a>
        @RenderSection("PageMenu", required: false)
        <a href="@Url.Content("~/Settings")">Settings</a>

        @if (Context.Session.GetString("Username") != null)
        {
            <a href="@Url.Content("~/Logout")" class="ms-auto">Logout</a>
        } *@
    </nav>



    <!-- Main content -->
    <div class="content">
        @RenderBody()
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>
