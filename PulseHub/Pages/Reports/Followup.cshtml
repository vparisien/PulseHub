@page
@model PulseHub.Pages.Reports.FollowupModel
@{
    ViewData["Title"] = "Follow-up Status Report";
}

<div class="container-fluid mt-4">
    <div class="d-flex align-items-center mb-4 gap-3">
        <a href="/Reports" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Reports
        </a>
        <div>
            <h2 class="fw-bold mb-0"><i class="bi bi-flag-fill text-danger me-2"></i>Follow-up Status</h2>
            <small class="text-muted">Red-flagged sessions grouped by order — track action status</small>
        </div>
    </div>

    <!-- Filter Bar -->
    <div class="card shadow-sm mb-4">
        <div class="card-body py-3">
            <form method="get">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Start Date</label>
                        <input type="date" name="StartDate" value="@Model.StartDate?.ToString("yyyy-MM-dd")" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">End Date</label>
                        <input type="date" name="EndDate" value="@Model.EndDate?.ToString("yyyy-MM-dd")" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-funnel me-1"></i> Apply
                        </button>
                    </div>
                    <div class="col-md-2">
                        <a href="/Reports/Followup" class="btn btn-outline-secondary w-100">Reset</a>
                    </div>
                    <div class="col-auto ms-auto align-self-center">
                        <span class="badge bg-danger me-1 px-3 py-2">
                            <i class="bi bi-hourglass-split me-1"></i> Pending: @Model.PendingCount
                        </span>
                        <span class="badge bg-success px-3 py-2">
                            <i class="bi bi-check-circle me-1"></i> Actioned: @Model.ActionedCount
                        </span>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Sessions.Any())
    {
        <!-- Hidden antiforgery token for AJAX -->
        <form id="ajaxTokenForm">@Html.AntiForgeryToken()</form>

        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm mb-0 align-middle">
                        <thead class="table-dark sortable-header">
                            <tr>
                                <th class="ps-3 sortable" data-col="0">Status <span class="sort-icon">⇅</span></th>
                                <th class="sortable" data-col="1">Date <span class="sort-icon">⇅</span></th>
                                <th class="sortable" data-col="2">Store # <span class="sort-icon">⇅</span></th>
                                <th class="sortable" data-col="3">Order # <span class="sort-icon">⇅</span></th>
                                <th class="sortable" data-col="4">Customer <span class="sort-icon">⇅</span></th>
                                <th class="sortable" data-col="5">Assigned To <span class="sort-icon">⇅</span></th>
                                <th class="sortable" data-col="6">Flagged <span class="sort-icon">⇅</span></th>
                                <th class="sortable" data-col="7">Responded <span class="sort-icon">⇅</span></th>
                                <th>Response(s)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var session in Model.Sessions)
                            {
                                var isPending = session.ActionStatus == "Pending";
                                <tr class="@(isPending ? "table-danger" : "table-success")">
                                    <td class="ps-3">
                                        @if (isPending)
                                        {
                                            <span class="badge bg-danger"><i class="bi bi-hourglass-split me-1"></i>Pending</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Actioned</span>
                                        }
                                    </td>
                                    <td class="text-nowrap">@session.TransactionDate.ToString("yyyy-MM-dd")</td>
                                    <td><span class="badge bg-secondary">@session.StoreNumber?.Trim()</span></td>
                                    <td>
                                        <code class="order-link session-trigger"
                                              style="cursor:pointer; text-decoration:underline; color:#0d6efd;"
                                              data-session='@System.Text.Json.JsonSerializer.Serialize(session)'>
                                            @session.OrderNumber
                                        </code>
                                        @if (session.FlaggedCount > 1)
                                        {
                                            <span class="badge bg-warning text-dark ms-1">@session.FlaggedCount items</span>
                                        }
                                    </td>
                                    <td>
                                        <div>@session.CustomerName</div>
                                        <div class="text-muted small">@session.CustomerEmail</div>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(session.ManagerName))
                                        {
                                            <div class="fw-bold">@session.ManagerName</div>
                                            <div class="text-muted small fst-italic">@session.ManagerTitle</div>
                                        }
                                        else if (!string.IsNullOrEmpty(session.AssignedTo))
                                        {
                                            <span class="text-muted fst-italic">#@session.AssignedTo</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td class="text-nowrap small">@session.CuratedAt?.ToString("yyyy-MM-dd")</td>
                                    <td class="text-nowrap small">
                                        @if (session.RespondedAt.HasValue)
                                        {
                                            @session.RespondedAt.Value.ToString("yyyy-MM-dd")
                                        }
                                        else
                                        {
                                            <span class="text-danger fst-italic">—</span>
                                        }
                                    </td>
                                    <td class="small" style="max-width:320px;">
                                        @if (!string.IsNullOrEmpty(session.AnswerText))
                                        {
                                            var parts = session.AnswerText.Split("||");
                                            for (int i = 0; i < parts.Length; i++)
                                            {
                                                <span>@parts[i].Trim()</span>
                                                if (i < parts.Length - 1)
                                                {
                                                    <hr class="my-1" />
                                                }
                                            }
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>No follow-up items found for the selected date range.
        </div>
    }
</div>

<!-- Session Detail Modal -->
<div class="modal fade" id="sessionModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title"><i class="bi bi-flag-fill text-danger me-2"></i>Follow-up: <span id="modalOrderNum"></span></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="modalSessionId" />

                <!-- Manager info (read-only) -->
                <div class="alert alert-secondary py-2 mb-3" id="modalManagerInfo"></div>

                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Category</label>
                        <select id="modalCategory" class="form-select" onchange="filterSubCategories()">
                            <option value="">-- Select --</option>
                            @foreach (var cat in Model.Categories)
                            {
                                <option value="@cat.CategoryID">@cat.Category</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Sub-Category</label>
                        <select id="modalSubCategory" class="form-select">
                            <option value="">-- Select --</option>
                            @foreach (var sub in Model.SubCategories)
                            {
                                <option value="@sub.SubCategoryID" data-parent="@sub.CategoryID">@sub.SubCategory</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Department</label>
                        <select id="modalDepartment" class="form-select">
                            <option value="">-- Select --</option>
                            @foreach (var dept in Model.Departments)
                            {
                                <option value="@dept.DepartmentID">@dept.Department</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Curator Comment</label>
                    <textarea id="modalCuratorComment" class="form-control" rows="2"></textarea>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold small">Manager Comment</label>
                        <textarea id="modalManagerComment" class="form-control form-control-sm" rows="2"></textarea>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold small">Associate Comment</label>
                        <textarea id="modalAssociateComment" class="form-control form-control-sm" rows="2"></textarea>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold small">Customer Comment</label>
                    <textarea id="modalCustomerComment" class="form-control form-control-sm" rows="2"></textarea>
                </div>

                <div class="d-flex align-items-center gap-4">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="modalActionable" />
                        <label class="form-check-label fw-bold" for="modalActionable">Actionable</label>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="modalResponded" />
                        <label class="form-check-label fw-bold" for="modalResponded">
                            <span class="text-success">Mark as Responded</span>
                        </label>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="saveBtn" onclick="saveSession()">Save Changes</button>
            </div>
        </div>
    </div>
</div>

<!-- Toast -->
<div id="saveToast" class="toast align-items-center border-0" role="alert"
     style="position:fixed; bottom:1.5rem; right:1.5rem; z-index:9999; min-width:260px;">
    <div class="d-flex">
        <div class="toast-body" id="saveToastMessage"></div>
        <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast"></button>
    </div>
</div>

@section Scripts {
<style>
    th.sortable { cursor: pointer; user-select: none; white-space: nowrap; }
    th.sortable:hover { background-color: rgba(255,255,255,0.1); }
    th.sortable .sort-icon { opacity: 0.4; font-size: 0.75rem; }
    th.sortable.asc .sort-icon::before { content: "▲"; opacity: 1; }
    th.sortable.desc .sort-icon::before { content: "▼"; opacity: 1; }
    th.sortable.asc .sort-icon, th.sortable.desc .sort-icon { opacity: 1; }
</style>
<script>
    let currentModal, saveToast;

    document.addEventListener('DOMContentLoaded', function () {
        currentModal = new bootstrap.Modal(document.getElementById('sessionModal'));
        saveToast = new bootstrap.Toast(document.getElementById('saveToast'), { delay: 4000 });

        document.querySelectorAll('.session-trigger').forEach(trigger => {
            trigger.addEventListener('click', function () {
                const session = JSON.parse(this.getAttribute('data-session'));
                openModal(session);
            });
        });
    });

    function openModal(s) {
        document.getElementById('modalSessionId').value = s.ResponseSessionID;
        document.getElementById('modalOrderNum').innerText = s.OrderNumber || 'N/A';

        // Manager info banner
        const mgr = s.ManagerName
            ? `<i class="bi bi-person-fill me-1"></i><strong>${s.ManagerName}</strong> — ${s.ManagerTitle || ''} <span class="text-muted">(#${s.AssignedTo})</span>`
            : `<i class="bi bi-person me-1"></i>Assigned to: <span class="text-muted">#${s.AssignedTo || 'Unassigned'}</span>`;
        document.getElementById('modalManagerInfo').innerHTML = mgr;

        // Dropdowns
        document.getElementById('modalCategory').value = s.CategoryID || '';
        filterSubCategories();
        document.getElementById('modalSubCategory').value = s.SubCategoryID || '';
        document.getElementById('modalDepartment').value = s.DepartmentID || '';

        // Comments
        document.getElementById('modalCuratorComment').value = s.CuratorComment || '';
        document.getElementById('modalManagerComment').value = s.ManagerComment || '';
        document.getElementById('modalAssociateComment').value = s.AssociateComment || '';
        document.getElementById('modalCustomerComment').value = s.CustomerComment || '';

        // Toggles
        document.getElementById('modalActionable').checked = s.Actionable === true;
        document.getElementById('modalResponded').checked = s.RespondedAt !== null;

        currentModal.show();
    }

    function filterSubCategories() {
        const categoryId = document.getElementById('modalCategory').value;
        document.querySelectorAll('#modalSubCategory option').forEach(opt => {
            if (!opt.value) return;
            const match = !categoryId || opt.getAttribute('data-parent') === categoryId;
            opt.style.display = match ? 'block' : 'none';
            if (!match && document.getElementById('modalSubCategory').value === opt.value)
                document.getElementById('modalSubCategory').value = '';
        });
    }

    async function saveSession() {
        const saveBtn = document.getElementById('saveBtn');
        saveBtn.disabled = true;
        saveBtn.textContent = 'Saving...';

        const sessionId = parseInt(document.getElementById('modalSessionId').value);
        const responded = document.getElementById('modalResponded').checked;

        const data = {
            ResponseSessionId: sessionId,
            CategoryID: document.getElementById('modalCategory').value ? parseInt(document.getElementById('modalCategory').value) : null,
            SubCategoryID: document.getElementById('modalSubCategory').value ? parseInt(document.getElementById('modalSubCategory').value) : null,
            DepartmentID: document.getElementById('modalDepartment').value ? parseInt(document.getElementById('modalDepartment').value) : null,
            CuratorComment: document.getElementById('modalCuratorComment').value,
            ManagerComment: document.getElementById('modalManagerComment').value,
            AssociateComment: document.getElementById('modalAssociateComment').value,
            CustomerComment: document.getElementById('modalCustomerComment').value,
            Actionable: document.getElementById('modalActionable').checked
        };

        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        try {
            const [sessionRes, respondedRes] = await Promise.all([
                fetch('?handler=UpdateSession', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                    body: JSON.stringify(data)
                }),
                fetch('?handler=MarkResponded', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                    body: JSON.stringify({ responseSessionId: sessionId, responded })
                })
            ]);

            if (sessionRes.ok && respondedRes.ok) {
                currentModal.hide();
                location.reload();
            } else {
                showToast('❌ Save failed. Please try again.', 'bg-danger text-white');
            }
        } catch (err) {
            console.error(err);
            showToast('❌ Network error. Please try again.', 'bg-danger text-white');
        } finally {
            saveBtn.disabled = false;
            saveBtn.textContent = 'Save Changes';
        }
    }

    function showToast(msg, classes) {
        const el = document.getElementById('saveToast');
        el.className = 'toast align-items-center border-0 ' + classes;
        document.getElementById('saveToastMessage').textContent = msg;
        saveToast.show();
    }

    // ── Sortable columns ──────────────────────────────────────────────
    document.querySelectorAll('th.sortable').forEach(th => {
        th.addEventListener('click', function () {
            const table = this.closest('table');
            const tbody = table.querySelector('tbody');
            const col = parseInt(this.getAttribute('data-col'));
            const asc = !this.classList.contains('asc');

            table.querySelectorAll('th.sortable').forEach(h => h.classList.remove('asc', 'desc'));
            this.classList.add(asc ? 'asc' : 'desc');

            const rows = Array.from(tbody.querySelectorAll('tr'));
            rows.sort((a, b) => {
                const av = a.cells[col]?.innerText.trim() ?? '';
                const bv = b.cells[col]?.innerText.trim() ?? '';
                return asc ? av.localeCompare(bv, undefined, { numeric: true }) : bv.localeCompare(av, undefined, { numeric: true });
            });
            rows.forEach(r => tbody.appendChild(r));
        });
    });
</script>
}
