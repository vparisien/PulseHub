@page
@model PulseHub.Pages.Reports.FollowupModel
@{
    ViewData["Title"] = "Follow-up Status Report";
}

<div class="container-fluid mt-4">
    <div class="d-flex align-items-center mb-4 gap-3">
        <a href="/Reports" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Reports
        </a>
        <div>
            <h2 class="fw-bold mb-0"><i class="bi bi-flag-fill text-danger me-2"></i>Follow-up Status</h2>
            <small class="text-muted">Red-flagged responses assigned to managers — track action status</small>
        </div>
    </div>

    <!-- Filter Bar -->
    <div class="card shadow-sm mb-4">
        <div class="card-body py-3">
            <form method="get">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Start Date</label>
                        <input type="date" name="StartDate" value="@Model.StartDate?.ToString("yyyy-MM-dd")" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">End Date</label>
                        <input type="date" name="EndDate" value="@Model.EndDate?.ToString("yyyy-MM-dd")" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-funnel me-1"></i> Apply
                        </button>
                    </div>
                    <div class="col-md-2">
                        <a href="/Reports/Followup" class="btn btn-outline-secondary w-100">Reset</a>
                    </div>
                    <div class="col-auto ms-auto align-self-center">
                        <span class="badge bg-danger me-1 px-3 py-2">
                            <i class="bi bi-hourglass-split me-1"></i> Pending: @Model.PendingCount
                        </span>
                        <span class="badge bg-success px-3 py-2">
                            <i class="bi bi-check-circle me-1"></i> Actioned: @Model.ActionedCount
                        </span>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Rows.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm mb-0 align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th class="ps-3">Status</th>
                                <th>Date</th>
                                <th>Store #</th>
                                <th>Assigned To</th>
                                <th>Customer</th>
                                <th>Flagged</th>
                                <th>Responded</th>
                                <th>Comment</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.Rows)
                            {
                                var isPending = row.ActionStatus == "Pending";
                                <tr class="@(isPending ? "table-danger" : "table-success")">
                                    <td class="ps-3">
                                        @if (isPending)
                                        {
                                            <span class="badge bg-danger"><i class="bi bi-hourglass-split me-1"></i>Pending</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Actioned</span>
                                        }
                                    </td>
                                    <td class="text-nowrap">@row.TransactionDate.ToString("yyyy-MM-dd")</td>
                                    <td><span class="badge bg-secondary">@row.StoreNumber?.Trim()</span></td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(row.ManagerName))
                                        {
                                            <div class="fw-bold">@row.ManagerName</div>
                                            <div class="text-muted small">#@row.AssignedTo</div>
                                            @if (!string.IsNullOrEmpty(row.ManagerTitle))
                                            {
                                                <div class="text-muted small fst-italic">@row.ManagerTitle</div>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted fst-italic">#@row.AssignedTo</span>
                                        }
                                    </td>
                                    <td>
                                        <div>@row.CustomerName</div>
                                        <div class="text-muted small">@row.CustomerEmail</div>
                                    </td>
                                    <td class="text-nowrap small">@row.CuratedAt?.ToString("yyyy-MM-dd")</td>
                                    <td class="text-nowrap small">
                                        @if (row.RespondedAt.HasValue)
                                        {
                                            @row.RespondedAt.Value.ToString("yyyy-MM-dd")
                                        }
                                        else
                                        {
                                            <span class="text-danger fst-italic">—</span>
                                        }
                                    </td>
                                    <td class="text-muted small" style="max-width:280px;">@row.AnswerText</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>No follow-up items found for the selected date range.
        </div>
    }
</div>
