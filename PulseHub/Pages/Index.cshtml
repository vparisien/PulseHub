@page
@model PulseHub.Pages.IndexModel
@{
    ViewData["Title"] = "PulseHub Dashboard";
}

<div class="app-header text-center py-4 mb-5 shadow-sm bg-primary">
    <h1 class="display-5 fw-bold mb-0 text-white">PulseHub</h1>
    <p class="lead text-light">Customer Feedback. Actionable Insights. Store Engagement.</p>
</div>

<div class="container text-center">
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 justify-content-center">

        @if (Model.CanImportSurveys)
        {
            <div class="col">
                <a asp-page="/ImportSurveys" class="dashboard-card btn btn-success">
                    <i class="bi bi-file-earmark-arrow-up mb-2 fs-2"></i><br />
                    Import Surveys
                </a>
            </div>
        }

        @if (Model.CanCurateResponses)
        {
            <div class="col">
                <a asp-page="/CurateResponses" class="dashboard-card btn btn-warning">
                    <i class="bi bi-pencil-square mb-2 fs-2"></i><br />
                    Curate Responses
                </a>
            </div>
        }

        @if (Model.CanNotifyManagers)
        {
            <div class="col">
                <a asp-page="/NotifyManagers" class="dashboard-card btn btn-info">
                    <i class="bi bi-bell mb-2 fs-2"></i><br />
                    Notify Managers
                </a>
            </div>
        }

        @if (Model.CanViewReports)
        {
            <div class="col">
                <a asp-page="/Reports" class="dashboard-card btn btn-secondary">
                    <i class="bi bi-bar-chart-line mb-2 fs-2"></i><br />
                    Reports
                </a>
            </div>
        }

        @if (Model.CanAccessManagerView)
        {
            <div class="col">
                <a asp-page="/ManagerView" class="dashboard-card btn btn-primary">
                    <i class="bi bi-person-lines-fill mb-2 fs-2"></i><br />
                    Manager View
                </a>
            </div>
        }

        @if (Model.CanAccessAdmin)
        {
            <div class="col">
                <a asp-page="/Admin/Index" class="dashboard-card btn btn-danger">
                    <i class="bi bi-gear mb-2 fs-2"></i><br />
                    Admin
                </a>
            </div>
        }

    </div>
</div>

<footer class="text-center mt-5 text-muted small">
    &copy; @DateTime.Now.Year Laura Canada — All Rights Reserved
</footer>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">